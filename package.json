{
  "name": "phaser3game",
  "version": "1.0.0",
  "description": "Webpack5 + Phaser 3",
  "main": "index.js",
  "author": "Kingsley, Robert",
  "license": "MIT",
  "dependencies": {
    "@esotericsoftware/spine-phaser": "~4.1.0",
    "core-js": "^3.15.2",
    "crypto-js": "^4.0.0",
    "gsap": "^3.12.5",
    "json-long": "^0.0.2",
    "phaser": "^3.60.0",
    "protobufjs": "^7.2.4"
  },
  "devDependencies": {
    "@babel/core": "^7.21.8",
    "@babel/eslint-parser": "^7.21.8",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@types/node": "^24.5.2",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "babel-loader": "^9.1.2",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.7.4",
    "css-minimizer-webpack-plugin": "^5.0.0",
    "dat.gui": "^0.7.9",
    "eslint": "^8.41.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-import-resolver-webpack": "^0.13.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-babel": "^5.3.1",
    "eslint-plugin-import": "^2.27.5",
    "eslint-webpack-plugin": "^4.0.1",
    "git-rev-sync": "^3.0.2",
    "html-webpack-plugin": "^5.5.1",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss-loader": "^7.3.0",
    "prettier": "^2.8.8",
    "prettier-eslint": "^15.0.1",
    "sass": "^1.62.1",
    "sass-loader": "^13.3.0",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.2",
    "webpack": "^5.83.1",
    "webpack-cli": "^5.1.1",
    "webpack-dev-server": "^4.15.0",
    "webpack-merge": "^5.9.0"
  },
  "scripts": {
    "start": "cross-env Mode=dev webpack serve --config webpack/webpack.dev.js",
    "sub": "chmod +x sh/package.sh; ./sh/package.sh ",
    "sub:install": "yarn run sub clear; yarn run sub install",
    "sub:update": "yarn run sub update",
    "env": "chmod +x game.sh; ./game.sh",
    "env:install": "yarn run env envNew slot",
    "env:update": "yarn run env envUpdate slot",
    "build:dev": "cross-env Mode=dev node webpack/build.js",
    "build:master": "cross-env Mode=master node webpack/build.js",
    "assets:update": "chmod +x sh/assets_build.sh; ./sh/assets_build.sh",
    "macEnv:install": "chmod +x sh/install_mac_env.sh; ./sh/install_mac_env.sh",
    "lint": "eslint src || true",
    "typecheck": "tsc --noEmit"
  }
}
